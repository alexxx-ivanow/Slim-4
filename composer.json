{
    "require": {
        "doctrine/dbal": "2.13.8",
        "firebase/php-jwt": "^7.0",
        "gumlet/php-image-resize": "^2.1",
        "illuminate/database": "12.0.1",
        "inok/slim-validation4": "^1.0",
        "jasny/auth": "^2.2",
        "php-di/php-di": "^7.1",
        "selective/basepath": "^2.1",
        "slim/flash": "^0.4.0",
        "slim/php-view": "^3.4",
        "slim/psr7": "^1.8",
        "slim/slim": "4.*",
        "slim/twig-view": "^3.4.1"
    },
    "require-dev": {
        "php-debugbar/php-debugbar": "^2.2",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    }
}
